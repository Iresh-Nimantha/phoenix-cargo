{
  "entities": {
    "siteContent": {
      "title": "Site Content",
      "description": "General site content settings",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "tagline": { "type": "string" },
        "officeAddress": { "type": "string" },
        "phone1": { "type": "string" },
        "phone2": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["companyName"]
    }
  },
  "firestore": {
    "content/{contentId}": {
      "schema": "siteContent",
      "description": "Editable site content"
    }
  }
}
